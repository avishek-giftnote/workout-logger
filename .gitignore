tools/import_preview.json

# ── Secrets / env ─────────────────────────────────────────────────────────────
.env
.env.*
*.local
secrets/

# ── Java / Maven ──────────────────────────────────────────────────────────────
backend/target/
**/target/
*.class
.mvn/

# ── Node / frontend (future) ──────────────────────────────────────────────────
node_modules/
dist/
build/

# ── Bundled SPA (build artifact) — produced only inside the Docker image ───────
