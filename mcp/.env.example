# Local MCP identity + target. Copy to .env.local (git-ignored) and fill in.
# The server acts as ONE user — whichever account these resolve to.

# Where the backend REST API lives. Default shown; change for a remote/staging backend.
WORKOUT_LOGGER_API_URL=http://localhost:8080/api

# Identity — pick ONE:
#  (a) email + password: the server logs in at startup and caches the JWT for the session.
WORKOUT_LOGGER_EMAIL=you@example.com
WORKOUT_LOGGER_PASSWORD=change-me
#  (b) a pre-minted JWT (overrides a/b if set). Handy if you already have a token.
# WORKOUT_LOGGER_TOKEN=eyJ...
