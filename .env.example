# Copy to `.env` (chmod 600) on the VM and fill in. `.env` is git-ignored — NEVER commit real secrets.
#   cp .env.example .env && nano .env && chmod 600 .env

# MongoDB Atlas SRV connection string. Allowlist this VM's RESERVED public IP in Atlas → Network Access.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/workoutlogger?retryWrites=true&w=majority

# JWT signing secret — 32+ random bytes. Generate with:  openssl rand -base64 48
# A blank value refuses to boot under the prod profile (audit M7) — this is mandatory.
SECURITY_JWT_SECRET=

# Cloudflare Tunnel token. In the Cloudflare Zero Trust dashboard:
#   Networks → Tunnels → Create a tunnel → Cloudflared → (the install command shows `--token <THIS>`).
# Map the public hostname (e.g. app.yourdomain.com) → http://app:8080 in that same tunnel's config.
TUNNEL_TOKEN=

# ── Sentry (error monitoring). All OPTIONAL — leave blank to run without Sentry. ──────────────────
# Two projects on sentry.io: "workout-logger-backend" (Spring Boot) and "workout-logger-frontend" (React).
# DSNs are PUBLIC (safe to commit-adjacent here as a template, but the real values live only in this .env).
# Set SENTRY_RELEASE to the deploying commit so events + source maps group per deploy, e.g. at deploy time:
#   export SENTRY_RELEASE=$(git rev-parse --short HEAD)
SENTRY_DSN=                        # backend DSN (runtime) — "workout-logger-backend" project
VITE_SENTRY_DSN=                   # frontend DSN (baked into the bundle at BUILD) — "workout-logger-frontend"
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=                    # git SHA of the deploy (build + runtime); shared by FE and BE
SENTRY_TRACES_SAMPLE_RATE=0.1
# Source-map upload (BUILD-time only; NOT needed at runtime). SENTRY_AUTH_TOKEN is a real SECRET
# (org token with project:releases) — passed to `docker build` as a build ARG (Railway's builder rejects
# BuildKit secret mounts). It lands in `docker history`, so keep the image private + rotate the token.
SENTRY_ORG=                        # your Sentry org slug
SENTRY_PROJECT=workout-logger-frontend
SENTRY_AUTH_TOKEN=                 # SECRET — enables de-minified frontend stack traces
