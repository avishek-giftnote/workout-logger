# The variables the app reads. **Railway is the deployment platform** — set these in the service's
# Variables tab (Railway injects PORT itself; nothing here needs to be a file in production).
#
# This file doubles as the reference for a local run: `cp .env.example .env` (git-ignored, chmod 600).
# NEVER commit real secrets.

# ── Runtime (backend) ────────────────────────────────────────────────────────────────────────────
# MongoDB Atlas SRV connection string. Atlas → Network Access must allow Railway's egress.
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/workoutlogger?retryWrites=true&w=majority

# JWT signing secret — 32+ random bytes. Generate with:  openssl rand -base64 48
# A blank value refuses to boot under the prod profile (audit M7) — this is mandatory.
SECURITY_JWT_SECRET=

# 'prod' activates the M7 JWT fail-fast and disables the !prod DebugController.
SPRING_PROFILES_ACTIVE=prod

# ── Sentry (error monitoring). All OPTIONAL — leave blank to run without Sentry. ──────────────────
# Two projects on sentry.io: "workout-logger-backend" (Spring Boot) and "workout-logger-frontend" (React).
# DSNs are PUBLIC values; only SENTRY_AUTH_TOKEN is a real secret.
#
# Release tagging is automatic on Railway: the Dockerfile declares `ARG RAILWAY_GIT_COMMIT_SHA`, so the
# builder passes the deployed commit through and events group per deploy. (A Railway variable *reference*
# — ${{RAILWAY_GIT_COMMIT_SHA}} — does NOT work: it resolves to "" and silently defeats the default.)
SENTRY_DSN=                        # backend DSN (RUNTIME) — "workout-logger-backend" project
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# BUILD-time: baked into the JS bundle. Railway maps a service variable onto the matching Dockerfile ARG.
VITE_SENTRY_DSN=                   # frontend DSN — "workout-logger-frontend" project

# Source-map upload (BUILD-time only; NOT needed at runtime) — gives de-minified frontend stack traces.
# SENTRY_AUTH_TOKEN is a real SECRET (org token with project:releases). It is passed as a plain build ARG
# because Railway's builder rejects BuildKit secret mounts, so it lands in `docker history` — keep the
# image private and use a short-lived token. Currently UNSET in prod (see DEPLOY.md).
SENTRY_ORG=                        # your Sentry org slug
SENTRY_PROJECT=workout-logger-frontend
SENTRY_AUTH_TOKEN=                 # SECRET — enables de-minified frontend stack traces
